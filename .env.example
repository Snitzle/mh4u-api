APP_NAME="MH4U Database API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# The whole project (web + mobile clients) talks to the API on :8088.
# Run the dev server with `php artisan serve --port=8088` (or `docker compose up`).
APP_URL=http://localhost:8088

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local dev runs MySQL in Docker (see docker-compose.yml); these defaults match
# the `mysql` service and `docker compose up` wires them up automatically.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=mh4u_api
DB_USERNAME=mh4u
DB_PASSWORD=secret
# Running natively (no Docker)? Use the mapped host port — DB_HOST=127.0.0.1,
# DB_PORT=3307 — or SQLite: DB_CONNECTION=sqlite + `touch database/database.sqlite`.

# Absolute base URL for image assets (icon_url, map_url). Points at the CDN in prod.
MH4U_ASSET_BASE_URL="${APP_URL}/assets"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache (and the API rate limiter) use Redis, served by the `redis` container.
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SCOUT_DRIVER=database
